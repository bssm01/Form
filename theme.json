{
  "name": "auth-saas-design-system",
  "description": "Semantic design tokens for the application UI",
  "theme": {
    "colors": {
      "background": "#FFFFFF",
      "foreground": "#262626",
      "card": "#FFFFFF",
      "cardForeground": "#262626",
      "popover": "#FFFFFF",
      "popoverForeground": "#262626",
      "primary": "#0095F6",
      "primaryForeground": "#FFFFFF",
      "secondary": "#EFEFEF",
      "secondaryForeground": "#262626",
      "muted": "#F5F5F5",
      "mutedForeground": "#8E8E8E",
      "accent": "#0095F6",
      "accentForeground": "#FFFFFF",
      "destructive": "#ED4956",
      "destructiveForeground": "#FFFFFF",
      "border": "#DBDBDB",
      "input": "#DBDBDB",
      "ring": "#0095F6",
      "success": "#22C55E",
      "warning": "#F59E0B",
      "info": "#0095F6",
      "gradientStart": "#833AB4",
      "gradientMid": "#FD1D1D",
      "gradientEnd": "#F77737"
    },
    "radius": {
      "sm": "0.375rem",
      "md": "0.5rem",
      "lg": "0.75rem",
      "xl": "0.75rem",
      "2xl": "1rem",
      "full": "9999px"
    },
    "spacing": {
      "xs": "0.25rem",
      "sm": "0.5rem",
      "md": "0.75rem",
      "lg": "1rem",
      "xl": "1.5rem",
      "2xl": "2rem",
      "3xl": "3rem"
    },
    "typography": {
      "fontFamily": "Geist, ui-sans-serif, system-ui, sans-serif",
      "fontSize": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem",
        "3xl": "1.875rem"
      },
      "fontWeight": {
        "normal": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "lineHeight": {
        "tight": "1.2",
        "normal": "1.5"
      }
    },
    "shadows": {
      "sm": "0 1px 2px rgba(0, 0, 0, 0.05)",
      "md": "0 4px 8px rgba(0, 0, 0, 0.08)",
      "lg": "0 10px 20px rgba(0, 0, 0, 0.12)"
    }
  }
}
